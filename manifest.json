{
  "manifest_version": 3,
  "name": "Forger",
  "version": "1.6.0",
  "description": "Smart keyword list generator using web scrapping.",
  "permissions": ["activeTab", "scripting", "downloads"],
  "action": {
    "default_title": "Generate List",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "web_accessible_resources": [{
    "resources": [
      "data/stopwords/*.json",
      "data/blacklist/*.json",
      "data/whitelist/*.json"
    ],
    "matches": [
      "<all_urls>"
    ]
  }]

}
